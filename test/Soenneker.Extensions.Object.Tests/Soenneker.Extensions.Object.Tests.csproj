<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <IsPackable>false</IsPackable>
        <UseMicrosoftTestingPlatform>false</UseMicrosoftTestingPlatform>
    </PropertyGroup>

    <ItemGroup>
        <None Remove="appsettings.json" />
    </ItemGroup>

    <ItemGroup>
        <Content Include="appsettings.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Soenneker.Dtos.StreetAddress" Version="4.0.505" />
        <PackageReference Include="Soenneker.Tests.Attributes.Local" Version="4.0.0" />
        <PackageReference Include="Soenneker.Facts.Manual" Version="4.0.174" />
        <PackageReference Include="Soenneker.Tests.Benchmark" Version="4.0.81" />
        <PackageReference Include="Soenneker.Tests.HostedUnit" Version="4.0.13" />
        <PackageReference Include="Soenneker.Utils.Test" Version="4.0.314" />
        <PackageReference Include="TUnit" Version="1.37.24" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\Soenneker.Extensions.Object\Soenneker.Extensions.Object.csproj" />
    </ItemGroup>

    <ItemGroup>
        <Content Include="testconfig.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>
</Project>
