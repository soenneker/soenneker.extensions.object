<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <IsPackable>false</IsPackable>
        <UseMicrosoftTestingPlatform>false</UseMicrosoftTestingPlatform>
    </PropertyGroup>

    <ItemGroup>
        <None Remove="appsettings.json" />
    </ItemGroup>

    <ItemGroup>
        <Content Include="appsettings.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Soenneker.Dtos.StreetAddress" Version="4.0.513" />
        <PackageReference Include="Soenneker.Tests.Attributes.Local" Version="4.0.41" />
        <PackageReference Include="Soenneker.Tests.Benchmark" Version="4.0.118" />
        <PackageReference Include="Soenneker.Tests.HostedUnit" Version="4.0.94" />
        <PackageReference Include="Soenneker.Utils.Test" Version="4.0.320" />
        <PackageReference Include="TUnit" Version="1.56.18" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\Soenneker.Extensions.Object\Soenneker.Extensions.Object.csproj" />
    </ItemGroup>
</Project>



